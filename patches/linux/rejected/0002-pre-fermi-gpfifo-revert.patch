 	struct nouveau_fence *fence = exec_job->fence;
 	int i, ret;
 
-	ret = nvif_chan_gpfifo_wait(&chan->chan, exec_job->push.count + 1, 16);
+	if (chan->user.oclass < FERMI_CHANNEL_GPFIFO)
