 drivers/gpu/drm/nouveau/nouveau_chan.h  |   5 ++
 drivers/gpu/drm/nouveau/nouveau_dma.c   | 108 +++++++++++++++++++++++-
 drivers/gpu/drm/nouveau/nouveau_dma.h   |  13 ++-
 drivers/gpu/drm/nouveau/nouveau_exec.c  |  18 +++-
 drivers/gpu/drm/nouveau/nouveau_gem.c   |  22 ++++-
 7 files changed, 168 insertions(+), 18 deletions(-)

